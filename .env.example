# ── Database ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=contaflow_erp
POSTGRES_USER=contaflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};Include Error Detail=true

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──
JWT_KEY=CHANGE_ME_AT_LEAST_32_CHARACTERS_SECRET
JWT_ISSUER=ContaFlow.API
JWT_AUDIENCE=ContaFlow.Client
JWT_EXPIRES_MINUTES=480

# ── Kafka ──
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Email / SMTP ──
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=mailpit
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=ContaFlow ERP
EMAIL_FROM_EMAIL=noreply@contaflow.com
EMAIL_USE_SSL=false
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# ── Backend ──
ASPNETCORE_ENVIRONMENT=Development
BACKEND_URL=http://localhost:8080

# ── Frontend ──
NEXT_PUBLIC_BACKEND_URL=
PORT=3000

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Next.js (server-side) ──
DATABASE_URL_PRISMA=postgresql://contaflow:CHANGE_ME_STRONG_PASSWORD@localhost:5432/contaflow_erp
