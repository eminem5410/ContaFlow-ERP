# ── ContaFlow .NET Backend — Environment Template ────────────────
# Copy this file to .env and fill in your values.
# These override appsettings.json values when present.

# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=contaflow_erp;Username=contaflow;Password=CHANGE_ME
ConnectionStrings__Redis=localhost:6379

# JWT Authentication (min 32 chars!)
Jwt__Key=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS
Jwt__Issuer=ContaFlow.API
Jwt__Audience=ContaFlow.Client
Jwt__ExpiresInMinutes=480

# CORS
Cors__AllowedOrigins=http://localhost:3000

# Kafka
Kafka__Enabled=true
Kafka__BootstrapServers=localhost:9092
Kafka__ClientId=contaflow-producer
Kafka__ConsumerGroupId=contaflow-consumer-group

# Redis
Redis__Enabled=true
Redis__InstancePrefix=contaflow:

# Environment
ASPNETCORE_ENVIRONMENT=Development
