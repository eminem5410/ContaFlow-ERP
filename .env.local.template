# ══════════════════════════════════════════════════════════════════════════
# ContaFlow ERP — Configuracion Local (Windows + Docker Desktop)
# ══════════════════════════════════════════════════════════════════════════
# Copiar a .env y ajustar los valores que necesites.
#
# Los valores por defecto aca funcionan para desarrollo local.
# Solo cambiá POSTGRES_PASSWORD y JWT_KEY si queres mayor seguridad.
# ══════════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=contaflow_erp
POSTGRES_USER=contaflow
POSTGRES_PASSWORD=contaflow_local_dev_2024

# EF Core connection string (.NET backend)
DATABASE_URL=Host=postgres;Port=5432;Database=contaflow_erp;Username=contaflow;Password=contaflow_local_dev_2024;Include Error Detail=true

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT Authentication ──────────────────────────────────────────────────
# Minimo 32 caracteres!
JWT_KEY=contaflow_local_jwt_secret_key_2024_dev
JWT_ISSUER=ContaFlow.API
JWT_AUDIENCE=ContaFlow.Client
JWT_EXPIRES_MINUTES=480

# ── Kafka ───────────────────────────────────────────────────────────────
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Email / SMTP ────────────────────────────────────────────────────────
# Usamos Mailpit (SMTP de testing incluido en Docker Compose)
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=mailpit
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=ContaFlow ERP
EMAIL_FROM_EMAIL=noreply@contaflow.com
EMAIL_USE_SSL=false

# ── Mailpit (SMTP testing UI) ───────────────────────────────────────────
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# ── Backend ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
BACKEND_URL=http://backend:8080

# ── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=
PORT=3000

# ── CORS (origenes permitidos, separados por coma) ──────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080

# ── Prisma connection (Next.js server-side) ─────────────────────────────
DATABASE_URL_PRISMA=postgresql://contaflow:contaflow_local_dev_2024@postgres:5432/contaflow_erp

# ── Docker Compose ports (solo si queres cambiar los puertos host) ──────
NGINX_PORT=80
APP_PORT=3000
BACKEND_PORT=8080
